# Copy to backend/.env and fill in real values.

# Async SQLAlchemy URL (asyncpg driver) pointing at a PostGIS-enabled database.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hybrid_routing

# Google Distance Matrix API — required for the fallback (estimated) path.
# Without a valid key, fallback searches will return HTTP 502; exact-match
# searches near a demo origin still return their exact demo jobs (HTTP 200).
GOOGLE_DISTANCE_MATRIX_API_KEY=
GOOGLE_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json

# Google Directions API — used only by the offline booth demo route-cache
# pre-computation script (scripts/generate_route_cache.py). Not read by the
# running FastAPI app.
GOOGLE_API_KEY=

# Booth Demo Mode — when true, GET /search serves commute estimates from the
# pre-computed booth_route_cache.json instead of the live Google API. Leave
# false/unset for normal (live) operation.
BOOTH_DEMO_MODE=false
BOOTH_ROUTE_CACHE_PATH=booth_route_cache.json
